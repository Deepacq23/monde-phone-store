# Supabase project settings — Project Settings > API in the Supabase dashboard.
# If these are left unset, the site falls back to local seed data automatically
# (see src/lib/seed-data.ts) so the design can be previewed without a database.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Comma-separated list of emails allowed to access admin-only features.
ALLOWED_ADMIN_EMAILS=

# Public site URL used for metadata, Open Graph tags, and the sitemap.
# Set this to the real production domain once one exists.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
